{
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": [
            "DbExport.Api/DbExport.Api.csproj"
          ]
        }
      ],
      "dest": "docs/api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "README.md",
          "toc.yml",
          "docs/**/*.md",
          "docs/api/**.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "docs/screenshots/**",
          "styles/**"
        ]
      }
    ],
    "dest": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appTitle": "DbExport Documentation",
      "_appName": "DbExport",
      "_enableSearch": true
    }
  }
}
