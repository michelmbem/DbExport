{
  "metadata": [
    {
      "src": [
        {
          "src": "src",
          "files": [
            "DbExport.Api/DbExport.Api.csproj"
          ]
        }
      ],
      "dest": "docs/api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "README.md"
        ]
      },
      {
        "src": "docs",
        "files": [
          "**/*.md",
          "**/toc.yml",
          "api/**/*.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "docs/screenshots/**"
        ]
      },
      {
        "src": "docs/styles",
        "files": [
          "**/*.css"
        ],
        "dest": "styles"
      }
    ],
    "dest": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appTitle": "DbExport Documentation",
      "_appName": "DbExport",
      "_enableSearch": true
    }
  }
}
