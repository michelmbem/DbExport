{
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": [
            "DbExport.Api/DbExport.Api.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "README.md",
          "docs/**/*.md",
          "api/**.yml",
          "api/index.md",
          "toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "docs/screenshots/**"
        ]
      }
    ],
    "dest": "_site",
    "template": [
      "default"
    ],
    "globalMetadata": {
      "_appTitle": "DbExport Documentation",
      "_appName": "DbExport",
      "_enableSearch": true
    }
  }
}
